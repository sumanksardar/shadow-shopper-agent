{
  "manifest_version": 3,
  "name": "Shadow Shopper Agent",
  "version": "1.0.0",
  "description": "Universal AI fraud detection and supply-chain analysis for any e-commerce product page.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shadow Shopper Agent"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
